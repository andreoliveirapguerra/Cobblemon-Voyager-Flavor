{
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.started = q.player.has_tag('voyager_met_lyra');",
    "v.landing_page = v.started ? 'main' : 'intro';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        "Você... Eu te conheço de algum lugar?"
      ],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "intro",
      "speaker": "player",
      "lines": [
        {
          "type": "expression",
          "expression": "'Acho que não, prazer em conhece-lo...'"
        }
      ],
      "input": [
        "v.callback_dialogue = 'lyra_chat01';",
        "c.npc.run_action_effect('change_dialogue_callback');",
        "q.run_script('run_callback_dialogue');",
        "q.dialogue.close();"
      ]
    },
    {
      "id": "main",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Ah sim, você é ' + q.player.username + ' o leal cãozinho do Vance...'"
        }
      ],
      "input": [
        "v.callback_dialogue = 'lyra_chat02';",
        "c.npc.run_action_effect('change_dialogue_callback');",
        "q.run_script('run_callback_dialogue');",
        "q.dialogue.close();"
      ]
    }
  ]
}