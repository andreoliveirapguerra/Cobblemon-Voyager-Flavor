{
  "startPage": "greeting",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_harpy');",
    "v.landing_page = v.met ? 'second_meeting' : 'first_contact';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "Harpy"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "first_contact",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Você... está carregando dois livros. Um de ferro e outro de cinzas. Interessante.'"
        },
        {"translate": "dialogue.voyager.harpy_first_contact.first_contact.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.harpy_first_contact.first_contact.option1"},
            "action": "q.dialogue.set_page('harpy_knowledge');"
          },
          {
            "text": {"translate": "dialogue.voyager.harpy_first_contact.first_contact.option2"},
            "action": "q.dialogue.set_page('harpy_knowledge');"
          }
        ]
      }
    },
    {
      "id": "harpy_knowledge",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_first_contact.harpy_knowledge.line1"},
        {"translate": "dialogue.voyager.harpy_first_contact.harpy_knowledge.line2"},
        {"translate": "dialogue.voyager.harpy_first_contact.harpy_knowledge.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.harpy_first_contact.harpy_knowledge.option1"},
            "action": "q.dialogue.set_page('sector_zero');"
          },
          {
            "text": {"translate": "dialogue.voyager.harpy_first_contact.harpy_knowledge.option2"},
            "action": "q.dialogue.set_page('trust');"
          }
        ]
      }
    },
    {
      "id": "sector_zero",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_first_contact.sector_zero.line1"},
        {"translate": "dialogue.voyager.harpy_first_contact.sector_zero.line2"},
        {"translate": "dialogue.voyager.harpy_first_contact.sector_zero.line3"}
      ],
      "input": {
        "type": "option",
        "options": [
          {
            "text": {"translate": "dialogue.voyager.harpy_first_contact.sector_zero.option1"},
            "action": [
              "q.run_command('give @p voyager_flavor:link_tunelamento 1');",
              "q.run_command('tag @p add voyager_met_harpy');",
              "q.dialogue.set_page('farewell');"
            ]
          }
        ]
      }
    },
    {
      "id": "trust",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_first_contact.trust.line1"},
        {"translate": "dialogue.voyager.harpy_first_contact.trust.line2"}
      ],
      "input": "q.dialogue.set_page('sector_zero');"
    },
    {
      "id": "farewell",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_first_contact.farewell.line1"},
        {"translate": "dialogue.voyager.harpy_first_contact.farewell.line2"}
      ],
      "input": "q.dialogue.close();"
    },
    {
      "id": "second_meeting",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_first_contact.second_meeting.line1"},
        {"translate": "dialogue.voyager.harpy_first_contact.second_meeting.line2"}
      ],
      "input": "q.dialogue.close();"
    }
  ]
}
