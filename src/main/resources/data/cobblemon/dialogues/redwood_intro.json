{
  "startPage": "greeting",
  "initializationAction": [
    "c.npc.set_chatting();"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greetings",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_intro.greetings.line1"}
      ],
      "input": "q.dialogue.set_page('briefing');"
    },
    {
      "id": "briefing",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_intro.briefing.line1"}
      ],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_intro.briefing.option1"},
            "action": "q.dialogue.set_page('explaining');"
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_intro.briefing.option2"},
            "action": "q.dialogue.set_page('good_luck');"
          }
        ]
      }
    },
    {
      "id": "explaining",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_intro.explaining.line1"},
        {"translate": "dialogue.voyager.redwood_intro.explaining.line2"},
        {"translate": "dialogue.voyager.redwood_intro.explaining.line3"}
      ],
      "input": "q.dialogue.set_page('explain_pt2');"
    },
    {
      "id": "explain_pt2",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Entendo, então seu nome é '+ q.player.username +'?'"
        }
      ],
      "input": [
        "q.run_command('voyager spawnRival ' + q.player.username);",
        "q.dialogue.set_page('rival_intro');"
      ]
    },
    {
      "id": "rival_intro",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_intro.rival_intro.line1"}
      ],
      "input": "q.dialogue.set_page('good_luck');"
    },
    {
      "id": "good_luck",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_intro.good_luck.line1"},
        {"translate": "dialogue.voyager.redwood_intro.good_luck.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_intro.good_luck.option1"},
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_journey_started');",
              "q.run_command('voyager startGame ' + q.player.username);",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    }
  ]
}
