{
  "startPage": "hub",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_hypnosgrunt');",
    "v.landing_page = v.met ? 'reencounter' : 'confrontation'"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "hub",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.hypnosgrunt_chat.hub.line1"}],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "confrontation",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.hypnosgrunt_chat.confrontation.line1"},
        {"translate": "dialogue.voyager.hypnosgrunt_chat.confrontation.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.hypnosgrunt_chat.confrontation.option1"},
            "action": "q.dialogue.set_page('battle_start');"
          },
          {
            "text": {"translate": "dialogue.voyager.hypnosgrunt_chat.confrontation.option2"},
            "action": "q.dialogue.set_page('hypnos_motives');"
          }
        ]
      }
    },
    {
      "id": "hypnos_motives",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.hypnosgrunt_chat.hypnos_motives.line1"},
        {"translate": "dialogue.voyager.hypnosgrunt_chat.hypnos_motives.line2"}
      ],
      "input": "q.dialogue.set_page('battle_start');"
    },
    {
      "id": "battle_start",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.hypnosgrunt_chat.battle_start.line1"}
      ],
      "input": [
        "q.npc.start_battle(q.player, 'single');",
        "q.run_command('tag ' + q.player.username + ' add voyager_met_hypnosgrunt');",
        "q.dialogue.close();"
      ]
    },
    {
      "id": "reencounter",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.hypnosgrunt_chat.reencounter.line1"},
        {"translate": "dialogue.voyager.hypnosgrunt_chat.reencounter.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.hypnosgrunt_chat.reencounter.option1"},
            "action": [
              "q.npc.start_battle(q.player, 'single');",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.hypnosgrunt_chat.reencounter.option2"},
            "action": "q.dialogue.close();"
          }
        ]
      }
    }
  ]
}
