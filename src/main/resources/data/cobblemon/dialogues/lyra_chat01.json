{
  "startPage": "v.landing_page",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_lyra');",
    "v.won = q.player.has_tag('voyager_won_lyra');",
    "v.landing_page = v.met? 'philosophy_challenge' : 'meeting",
    "v.landing_page = v.won? 'post_battle' : v.landing_page;"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "meeting",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Pare por um momento, Cadete. Consegue ouvir? Além do zumbido mecânico desses geradores de Redstone... há um silêncio que grita.'"
        },
        {"translate": "dialogue.voyager.lyra_chat01.meeting.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.lyra_chat01.meeting.option1"},
            "action": [
              "q.dialogue.set_page('lyra_introduction');",
              "q.run_command('tag '+q.player.username+' add voyager_met_lyra');"
            ]
          }
        ]
      }
    },
    {
      "id": "artifact_player",
      "speaker": "player",
      "lines": [
        {"translate": "dialogue.voyager.lyra_chat01.artifact_player.line1"}
      ],
      "input": [
        "q.dialogue.set_page('');"
      ]
    },
    {
      "id": "artifact_lyra",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.lyra_chat01.artifact_lyra.line1"},
        {"translate": "dialogue.voyager.lyra_chat01.artifact_lyra.line2"}
      ],
      "input": [
        "q.dialogue.set_page('lyra_introduction');"
      ]
    },
    {
      "id": "lyra_introduction",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.lyra_chat01.lyra_introduction.line1"},
        {"translate": "dialogue.voyager.lyra_chat01.lyra_introduction.line2"}
      ],
      "input": "q.dialogue.set_page('philosophy_challenge');"
    },
    {
      "id": "philosophy_challenge",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Diga-me, '+{q.player.name}+'... Se o seu Pokémon pudesse escolher entre a sua Pokébola tecnológica e a liberdade do Ultra-Vazio, você teria coragem de abrir a trava?'"
        },
        {"translate": "dialogue.voyager.lyra_chat01.philosophy_challenge.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.lyra_chat01.philosophy_challenge.option1"},
            "action": [
              "q.run_command('tag '+q.player.username+' add voyager_met_lyra');",
              "q.dialogue.close();",
              "q.npc.start_battle(q.player, 'single');"
            ]
          }
        ]
      }
    },
    {
      "id": "post_battle",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.lyra_chat01.post_battle.line1"},
        {"translate": "dialogue.voyager.lyra_chat01.post_battle.line2"}
      ],
      "input": [
        "q.dialogue.close();",
        "v.landing_page = 'goodbye'",
        "q.run_command('give '+q.player.username+' voyager-flavor:artifact');",
        "q.dialogue.set_page(v.landing_page);"
      ]
    },
    {
      "id": "goodbye",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.lyra_chat01.goodbye.line1"},
        {"translate": "dialogue.voyager.lyra_chat01.goodbye.line2"}
      ],
      "input": [
        "q.dialogue.close()"
      ]
    }
  ]
}
