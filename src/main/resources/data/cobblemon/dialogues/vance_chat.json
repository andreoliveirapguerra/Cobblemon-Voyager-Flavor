{
  "startPage": "v.landing_page",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_lyra');",
    "v.landing_page = v.met ? 'greeting' : 'post_battle';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greetings",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_chat.greetings.line1"},
        {"translate": "dialogue.voyager.vance_chat.greetings.line2"}
      ],
      "input": "q.dialogue.set_page('briefing');"
    },
    {
      "id": "briefing",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_chat.briefing.line1"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.vance_chat.briefing.option1"},
            "action": "q.dialogue.set_page('explaining');"
          },
          {
            "text": {"translate": "dialogue.voyager.vance_chat.briefing.option2"},
            "action": "q.dialogue.set_page('good_luck');"
          }
        ]
      }
    },
    {
      "id": "explaining",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_chat.explaining.line1"}
      ],
      "input": [
        "q.dialogue.close();",
        "q.npc.start_battle(q.player, 'single');"
      ]
    },
    {
      "id": "good_luck",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_chat.good_luck.line1"},
        {"translate": "dialogue.voyager.vance_chat.good_luck.line2"}
      ],
      "input": [
        "q.dialogue.close();",
        "q.npc.start_battle(q.player, 'single');"
      ]
    }
  ]
}
