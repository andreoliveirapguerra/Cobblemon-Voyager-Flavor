{
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.started = q.player.has_tag('voyager_journey_started');",
    "v.landing_page = v.started ? 'intro' : 'main';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        "[ Lendo dados do jogador... ]"
      ],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "intro",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Olá, ' + q.player.username + '! Vejo que você é novo por aqui.'"
        }
      ],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": "Iniciar Introdução",
            "action": [
              "v.callback_dialogue = 'redwood_intro';",
              "c.npc.run_action_effect('change_dialogue_callback');",
              "q.run_script('run_callback_dialogue');",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    },
    {
      "id": "main",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Bem-vindo de volta, ' + q.player.username + '!'"
        }
      ],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": "Iniciar Jogo",
            "action": [
              "v.callback_dialogue = 'redwood_chat';",
              "c.npc.run_action_effect('change_dialogue_callback');",
              "q.run_script('run_callback_dialogue');",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    }
  ]
}