{
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.healer = c.npc.find_nearby_block('cobblemon:healing_machine');",
    "v.has_healer = v.healer != 0;",
    "v.full_health = c.player.is_party_at_full_health();",
    "v.has_charge = v.has_healer == true && v.full_health == false && q.player.can_heal_at_healer(v.healer) == true;",
    "v.landing_page = !v.has_healer ? 'no_healer' : (v.full_health ? 'full_health' : (v.has_charge ? 'has_charge' : 'no_charge'));"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();",
      "gibber": {
      }
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "clientActions": [
        "q.face.play_animation('win');"
      ],
      "lines": [{"translate": "dialogue.voyager.ellie_chat.greeting.line1"}],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "no_healer",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.ellie_chat.no_healer.line1"},
        {"translate": "dialogue.voyager.ellie_chat.no_healer.line2"}
      ],
      "input": "q.dialogue.close();"
    },
    {
      "id": "full_health",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.ellie_chat.full_health.line1"}],
      "input": "q.dialogue.close();"
    },
    {
      "id": "no_charge",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.ellie_chat.no_charge.line1"}],
      "input": "q.dialogue.close();"
    },
    {
      "id": "has_charge",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.ellie_chat.has_charge.line1"}],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.ellie_chat.has_charge.option1"},
            "value": "yes",
            "action": [
              "v.callback_dialogue = 'sacchi_healed';",
              "c.npc.run_action_effect('npc_heal_player_pokemon');",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.ellie_chat.has_charge.option2"},
            "value": "no",
            "action": "q.dialogue.set_page('okbye');"
          }
        ]
      }
    },
    {
      "id": "okbye",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.ellie_chat.okbye.line1"}],
      "input": "q.dialogue.close();"
    }
  ]
}
