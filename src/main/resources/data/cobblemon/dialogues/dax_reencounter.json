{
  "startPage": "hub",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.won = q.player.has_tag('voyager_won_dax');",
    "v.landing_page = v.won ? 'chat_lost' : 'chat_won' "
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "hub",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.dax_reencounter.hub.line1"}],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "reencounter",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.dax_reencounter.reencounter.line1"}],
      "input": [
        "v.callback_dialogue = 'redwood_intro';",
        "c.npc.run_action_effect('change_dialogue_callback');",
        "q.dialogue.set_page(v.landing_page);"
      ]
    },
    {
      "id": "chat_lost",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Que? Você de novo ' + q.player.username + '?'"
        },
        {"translate": "dialogue.voyager.dax_reencounter.chat_lost.line2"},
        {"translate": "dialogue.voyager.dax_reencounter.chat_lost.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.chat_lost.option1"},
            "action": "q.dialogue.set_page('part2');"
          },
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.chat_lost.option2"},
            "action": "q.dialogue.set_page('part2');"
          }
        ]
      }
    },
    {
      "id": "chat_won",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Que? Você de novo ' + q.player.username + '?'"
        },
        {"translate": "dialogue.voyager.dax_reencounter.chat_won.line2"},
        {"translate": "dialogue.voyager.dax_reencounter.chat_won.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.chat_won.option1"},
            "action": "q.dialogue.set_page('part2');"
          },
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.chat_won.option2"},
            "action": "q.dialogue.set_page('part2');"
          }
        ]
      }
    },
    {
      "id": "part2",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.dax_reencounter.part2.line1"},
        {"translate": "dialogue.voyager.dax_reencounter.part2.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.part2.option1"},
            "value": "battle",
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_met_dax2 ');",
              "q.dialogue.close();",
              "q.npc.start_battle(q.player, 'single');"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.part2.option2"},
            "value": "battle",
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_met_dax2 ');",
              "q.dialogue.close();",
              "q.npc.start_battle(q.player, 'double');"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.dax_reencounter.part2.option3"},
            "value": "cancel",
            "action": [
              "q.dialogue.close();"
            ]
          }
        ]
      }
    }
  ]
}
