{
  "startPage": "greeting",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_elias');",
    "v.landing_page = v.met ? 'return' : 'greeting';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_main.greeting.line1"},
        {"translate": "dialogue.voyager.elias_main.greeting.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.elias_main.greeting.option1"},
            "action": "q.dialogue.set_page('sector_explain');"
          }
        ]
      }
    },
    {
      "id": "sector_explain",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_main.sector_explain.line1"},
        {"translate": "dialogue.voyager.elias_main.sector_explain.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.elias_main.sector_explain.option1"},
            "action": [
              "q.run_command('give ' + q.player.username + ' voyager-flavor:anti_radiation_suit 1');",
              "q.run_command('tag ' + q.player.username + ' add voyager_met_elias');",
              "q.dialogue.set_page('post_give');"
            ]
          }
        ]
      }
    },
    {
      "id": "post_give",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_main.post_give.line1"},
        {"translate": "dialogue.voyager.elias_main.post_give.line2"}
      ],
      "input": "q.dialogue.close();"
    },
    {
      "id": "return",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_main.return.line1"},
        {"translate": "dialogue.voyager.elias_main.return.line2"}
      ],
      "input": "q.dialogue.close();"
    }
  ]
}
