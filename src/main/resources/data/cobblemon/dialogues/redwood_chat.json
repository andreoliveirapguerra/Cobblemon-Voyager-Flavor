{
  "startPage": "greeting",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_redwood');",
    "v.cave = q.player.has_tag('voyager_cave_cleared');",
    "v.center = q.player.has_tag('voyager_at_center');",
    "v.lic = q.player.has_tag('voyager_has_license');",
    "v.landing_page = v.lic ? 'post_license' : (v.center ? 'arrival_at_center' : (v.cave ? 'ready_to_leave' : (v.met ? 'survival_tips' : 'crash_landing')));"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_chat.greeting.line1"}
      ],
      "input": [
        "v.landing_page = v.lic ? 'post_license' : (v.center ? 'arrival_at_center' : (v.cave ? 'ready_to_leave' : (v.met ? 'survival_tips' : 'crash_landing')));",
        "q.dialogue.set_page(v.landing_page);"
      ]
    },
    {
      "id": "crash_landing",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Finalmente você acordou ' + q.player.username + '! A queda foi feia... Os sensores de Redstone indicam que caímos em uma zona de instabilidade dimensional.'"
        },
        {"translate": "dialogue.voyager.redwood_chat.crash_landing.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.crash_landing.option1"},
            "action": [
              "q.run_command('voyager spawnCenter '+q.player.username);",
              "q.dialogue.set_page('give_quest');"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.crash_landing.option2"},
            "action": [
              "q.dialogue.set_page('give_quest');",
              "q.run_command('voyager spawnCenter '+q.player.username);"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.crash_landing.option3"},
            "action": [
              "q.dialogue.set_page('give_quest');",
              "q.run_command('voyager spawnCenter '+q.player.username);"
            ]
          }
        ]
      }
    },
    {
      "id": "give_quest",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_chat.give_quest.line1"},
        {"translate": "dialogue.voyager.redwood_chat.give_quest.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.give_quest.option1"},
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_met_redwood');",
              "q.run_command('voyager startcavechallenge ' + q.player.username);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.give_quest.option2"},
            "action": "q.dialogue.set_page('give_quest_extra_1');"
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.give_quest.option3"},
            "action": "q.dialogue.set_page('give_quest_extra_2');"
          }
        ]
      }
    },
    {
      "id": "give_quest_extra_1",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.redwood_chat.give_quest_extra_1.line1"},
