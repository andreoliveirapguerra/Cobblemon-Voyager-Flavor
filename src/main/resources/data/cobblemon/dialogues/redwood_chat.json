    },
    {
      "id": "survival_tips",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Mantenha o foco, Voyager ' + q.player.username + '! O ar aqui embaixo está carregado de partículas de energia negativa.'"
        },
        {"translate": "dialogue.voyager.redwood_chat.survival_tips.line2"}
      ],
      "input": {
        "type": "option",
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.survival_tips.option1"},
            "action": "q.dialogue.close();"
          }
        ]
      }
    },
    {
      "id": "ready_to_leave",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Trabalho impecável ' + q.player.username + '! O Ultra-Scanner confirmou: a atividade hostil de nível baixo cessou. Suas habilidades de combate superam as expectativas. Não há UltraBeasts(UB) por perto!'"
        },
        {"translate": "dialogue.voyager.redwood_chat.ready_to_leave.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.ready_to_leave.option1"},
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_at_center');",
              "q.run_command('voyager pokecentertp ' + q.player.username);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.ready_to_leave.option2"},
            "action": "q.dialogue.set_page('leave_extra');"
          },
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.ready_to_leave.option3"},
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_at_center');",
              "q.run_command('voyager pokecentertp ' + q.player.username);",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    },
    {
      "id": "leave_extra",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Não se preocupe, ' + q.player.username + ', eu calibrei a frequência para criptografar a nossa assinatura e fechar a conexão no instante em que passarmos. É seguro.'"
        },
        {"translate": "dialogue.voyager.redwood_chat.leave_extra.line2"}
      ],
      "input": {
        "type": "option",
        "options": [
          {
            "text": {"translate": "dialogue.voyager.redwood_chat.leave_extra.option1"},
