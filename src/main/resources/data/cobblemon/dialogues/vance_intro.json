{
  "startPage": "v.landing_page",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_lyra');",
    "v.landing_page = v.met ? 'greeting' : 'post_battle';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Muito bem cadete ' + q.player.username + ' eu reconheço seu potêncial.'"
        },
        {"translate": "dialogue.voyager.vance_intro.greeting.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.vance_intro.greeting.option1"},
            "action": "q.dialogue.set_page('challenge');"
          },
          {
            "text": {"translate": "dialogue.voyager.vance_intro.greeting.option2"},
            "action": "q.dialogue.set_page('challenge');"
          }
        ]
      }
    },
    {
      "id": "challenge",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_intro.challenge.line1"},
        {"translate": "dialogue.voyager.vance_intro.challenge.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.vance_intro.challenge.option1"},
            "value": "battle",
            "action": [
              "q.dialogue.close();",
              "q.run_command('voyager triggerLyraEvent ' +q.player.username);"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.vance_intro.challenge.option2"},
            "value": "battle",
            "action": [
              "q.dialogue.close();",
              "q.run_command('voyager triggerLyraEvent ' +q.player.username);"
            ]
          }
        ]
      }
    },
    {
      "id": "post_battle",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Bem vindo de volta cadete '+q.player.username"
        },
        {"translate": "dialogue.voyager.vance_intro.post_battle.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.vance_intro.post_battle.option1"},
            "action": [
              "q.run_command('tag ' + q.player.username + 'add voyager_doubt_1');",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.vance_intro.post_battle.option2"},
            "action": [
              "q.run_command('tag ' + q.player.username + 'add voyager_foundation_1');",
              "q.dialogue.set_page('revealed_truth');"
            ]
          }
        ]
      }
    },
    {
      "id": "revealed_truth",
      "speaker": "player",
      "lines": [
        {"translate": "dialogue.voyager.vance_intro.revealed_truth.line1"},
        {"translate": "dialogue.voyager.vance_intro.revealed_truth.line2"}
      ],
      "input": "q.dialogue.set_page('congrat_vance');"
    },
    {
      "id": "congrat_vance",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_intro.congrat_vance.line1"},
        {"translate": "dialogue.voyager.vance_intro.congrat_vance.line2"}
      ],
      "input": "q.dialogue.set_page('WIP');"
    },
    {
      "id": "WIP",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.vance_intro.WIP.line1"}
      ],
      "input": "q.dialogue.close();"
    }
  ]
}
