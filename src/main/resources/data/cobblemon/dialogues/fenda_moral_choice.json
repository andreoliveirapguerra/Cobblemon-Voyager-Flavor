{
  "startPage": "fenda_aparece",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.chose_order = q.player.has_tag('voyager_moral_order');",
    "v.chose_chaos = q.player.has_tag('voyager_moral_chaos');",
    "v.chose = v.chose_order || v.chose_chaos;",
    "v.landing_page = v.chose ? 'already_chose' : 'fenda_aparece';"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "'Harpy'"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "fenda_aparece",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.fenda_moral_choice.fenda_aparece.line1"},
        {"translate": "dialogue.voyager.fenda_moral_choice.fenda_aparece.line2"},
        {"translate": "dialogue.voyager.fenda_moral_choice.fenda_aparece.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.fenda_moral_choice.fenda_aparece.option1"},
            "action": [
              "q.run_command('voyager moralChoice order ' + q.player.username);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.fenda_moral_choice.fenda_aparece.option2"},
            "action": [
              "q.run_command('voyager moralChoice chaos ' + q.player.username);",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    },
    {
      "id": "already_chose",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.fenda_moral_choice.already_chose.line1"},
        {"translate": "dialogue.voyager.fenda_moral_choice.already_chose.line2"}
      ],
      "input": "q.dialogue.close();"
    }
  ]
}
