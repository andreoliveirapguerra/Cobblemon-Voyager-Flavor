{
  "startPage": "hub",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_elias');",
    "v.landing_page = v.met ? 'reencounter' : 'first_meeting'"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "hub",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.elias_chat.hub.line1"}],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "first_meeting",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Então... você desceu. Usou o Link da Harpy, né? Eu senti a distorção quando você atravessou a parede.'"
        },
        {"translate": "dialogue.voyager.elias_chat.first_meeting.line2"},
        {"translate": "dialogue.voyager.elias_chat.first_meeting.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.elias_chat.first_meeting.option1"},
            "action": "q.dialogue.set_page('sector_explain');"
          },
          {
            "text": {"translate": "dialogue.voyager.elias_chat.first_meeting.option2"},
            "action": "q.dialogue.set_page('harpy_question');"
          },
          {
            "text": {"translate": "dialogue.voyager.elias_chat.first_meeting.option3"},
            "action": "q.dialogue.set_page('anti_rad_suit');"
          }
        ]
      }
    },
    {
      "id": "sector_explain",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.sector_explain.line1"},
        {"translate": "dialogue.voyager.elias_chat.sector_explain.line2"},
        {"translate": "dialogue.voyager.elias_chat.sector_explain.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.elias_chat.sector_explain.option1"},
            "action": "q.dialogue.set_page('foundation_truth');"
          },
          {
            "text": {"translate": "dialogue.voyager.elias_chat.sector_explain.option2"},
            "action": "q.dialogue.set_page('anti_rad_suit');"
          }
        ]
      }
    },
    {
      "id": "foundation_truth",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.foundation_truth.line1"},
        {"translate": "dialogue.voyager.elias_chat.foundation_truth.line2"}
      ],
      "input": "q.dialogue.set_page('anti_rad_suit');"
    },
    {
      "id": "harpy_question",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.harpy_question.line1"},
        {"translate": "dialogue.voyager.elias_chat.harpy_question.line2"},
        {"translate": "dialogue.voyager.elias_chat.harpy_question.line3"}
      ],
      "input": "q.dialogue.set_page('anti_rad_suit');"
    },
    {
      "id": "anti_rad_suit",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.anti_rad_suit.line1"},
        {"translate": "dialogue.voyager.elias_chat.anti_rad_suit.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.elias_chat.anti_rad_suit.option1"},
            "action": [
              "q.run_command('give ' + q.player.username + ' voyager_flavor:anti_radiation_suit 1');",
              "q.run_command('tag ' + q.player.username + ' add voyager_met_elias');",
              "q.dialogue.set_page('farewell');"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.elias_chat.anti_rad_suit.option2"},
            "action": [
              "q.run_command('tag ' + q.player.username + ' add voyager_met_elias');",
              "q.dialogue.set_page('farewell');"
            ]
          }
        ]
      }
    },
    {
      "id": "farewell",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.farewell.line1"},
        {"translate": "dialogue.voyager.elias_chat.farewell.line2"}
      ],
      "input": "q.dialogue.close();"
    },
    {
      "id": "reencounter",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.reencounter.line1"},
        {"translate": "dialogue.voyager.elias_chat.reencounter.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.elias_chat.reencounter.option1"},
            "action": "q.dialogue.set_page('reencounter_help');"
          },
          {
            "text": {"translate": "dialogue.voyager.elias_chat.reencounter.option2"},
            "action": "q.dialogue.set_page('farewell');"
          }
        ]
      }
    },
    {
      "id": "reencounter_help",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.elias_chat.reencounter_help.line1"},
        {"translate": "dialogue.voyager.elias_chat.reencounter_help.line2"}
      ],
      "input": "q.dialogue.close();"
    }
  ]
}
