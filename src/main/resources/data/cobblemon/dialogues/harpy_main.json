{
  "startPage": "greeting",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_harpy');",
    "v.event13 = q.player.has_tag('voyager_ultra_event_13');",
    "v.landing_page = v.event13 ? 'fenda_choice' : (v.met ? 'return' : 'first_contact');"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "greeting",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_main.greeting.line1"}
      ],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "first_contact",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_main.first_contact.line1"},
        {"translate": "dialogue.voyager.harpy_main.first_contact.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.harpy_main.first_contact.option1"},
            "action": "q.dialogue.set_page('harpy_knowledge');"
          }
        ]
      }
    },
    {
      "id": "harpy_knowledge",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_main.harpy_knowledge.line1"},
        {"translate": "dialogue.voyager.harpy_main.harpy_knowledge.line2"},
        {"translate": "dialogue.voyager.harpy_main.harpy_knowledge.line3"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.harpy_main.harpy_knowledge.option1"},
            "action": [
              "q.run_command('voyager giveLinkTunelamento ' + q.player.username);",
              "q.run_command('voyager triggerUltraEvent 1 ' + q.player.username);",
              "q.run_command('tag ' + q.player.username + ' add voyager_met_harpy');",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    },
    {
      "id": "return",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_main.return.line1"},
        {"translate": "dialogue.voyager.harpy_main.return.line2"}
      ],
      "input": "q.dialogue.close();"
    },
    {
      "id": "fenda_choice",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.harpy_main.fenda_choice.line1"},
        {"translate": "dialogue.voyager.harpy_main.fenda_choice.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.harpy_main.fenda_choice.option1"},
            "action": [
              "q.run_command('voyager moralChoice order ' + q.player.username);",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.harpy_main.fenda_choice.option2"},
            "action": [
              "q.run_command('voyager moralChoice chaos ' + q.player.username);",
              "q.dialogue.close();"
            ]
          }
        ]
      }
    }
  ]
}
