{
  "startPage": "hub",
  "initializationAction": [
    "c.npc.set_chatting();",
    "v.met = q.player.has_tag('voyager_met_dax');",
    "v.landing_page = v.met ? 'reencounter' : 'meeting'"
  ],
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face();"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "hub",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.dax_initial_chat.hub.line1"}],
      "input": "q.dialogue.set_page(v.landing_page);"
    },
    {
      "id": "reencounter",
      "speaker": "npc",
      "lines": [{"translate": "dialogue.voyager.dax_initial_chat.reencounter.line1"}],
      "input": [
        "v.callback_dialogue = 'dax_reencounter';",
        "c.npc.run_action_effect('change_dialogue_callback');",
        "q.dialogue.close();"
      ]
    },
    {
      "id": "meeting",
      "speaker": "npc",
      "lines": [
        {
          "type": "expression",
          "expression": "'Hum, então você é o tal ' + q.player.username + '?'"
        },
        {"translate": "dialogue.voyager.dax_initial_chat.meeting.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.dax_initial_chat.meeting.option1"},
            "action": "q.dialogue.set_page('dax_identity');"
          },
          {
            "text": {"translate": "dialogue.voyager.dax_initial_chat.meeting.option2"},
            "action": "q.dialogue.set_page('dax_identity');"
          }
        ]
      }
    },
    {
      "id": "dax_identity",
      "speaker": "npc",
      "lines": [
        {"translate": "dialogue.voyager.dax_initial_chat.dax_identity.line1"},
        {"translate": "dialogue.voyager.dax_initial_chat.dax_identity.line2"}
      ],
      "input": {
        "type": "option",
        "vertical": true,
        "options": [
          {
            "text": {"translate": "dialogue.voyager.dax_initial_chat.dax_identity.option1"},
            "value": "battle",
            "action": [
              "q.npc.start_battle(q.player, 'single');",
              "q.run_command('tag ' + q.player.username + ' add voyager_met_dax');",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.dax_initial_chat.dax_identity.option2"},
            "value": "battle",
            "action": [
              "q.npc.start_battle(q.player, 'double');",
              "q.run_command('tag ' + q.player.username + ' add voyager_met_dax');",
              "q.dialogue.close();"
            ]
          },
          {
            "text": {"translate": "dialogue.voyager.dax_initial_chat.dax_identity.option3"},
            "value": "cancel",
            "action": [
              "q.dialogue.close();"
            ]
          }
        ]
      }
    }
  ]
}
